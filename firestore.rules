rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'admin@aptitudearcade.com'
      );
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /results/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isAdmin()
        || (isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.testKey is string
          && request.resource.data.score is number
          && request.resource.data.submittedAt is string);
      allow delete: if isAdmin();
    }

    match /exam_sessions/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow delete, update: if isAdmin();
      allow create: if false;
    }

    match /metrics/{testKey} {
      allow read: if isAdmin();
      allow write, delete: if isAdmin();
    }

    match /system_logs/{id} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /exam_results/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create, update: if isAdmin()
        || (isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.testKey is string
          && request.resource.data.score is number
          && request.resource.data.submittedAt is string);
      allow delete: if isAdmin();
    }

    match /student_progress/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isAdmin() || isOwner(uid);
      allow delete: if isAdmin();
    }

    match /help_requests/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /question_banks/{dayKey} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
